{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Checklist de révision",
  "version": "1.0.0",
  "identifier": "com.didiwork.checklist-revision",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Checklist de révision",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Checklist de révision pour projets d'architecture",
    "longDescription": "Application locale pour gérer des checklists de révision. Toutes les données restent sur la machine.",
    "copyright": "",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["French"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
